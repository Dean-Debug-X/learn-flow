# Core production settings
NODE_ENV=production
JWT_SECRET=replace-with-a-long-random-string
DATABASE_URL=mysql://user:password@host:3306/learnflow
PUBLIC_APP_URL=https://learn-flow-weld.vercel.app

# OAuth / auth
VITE_APP_ID=replace-with-your-app-id
OAUTH_SERVER_URL=https://your-oauth-server.example.com
OWNER_OPEN_ID=replace-with-owner-open-id
WECHAT_LOGIN_APP_ID=
WECHAT_LOGIN_APP_SECRET=
WECHAT_LOGIN_REDIRECT_URI=https://learn-flow-weld.vercel.app/api/auth/wechat/callback

# OTP login
SMS_PROVIDER=tencent
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID_LOGIN=

# Recommended storage on Vercel
STORAGE_DRIVER=s3
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
MEDIA_SIGNED_URL_TTL_SECONDS=300
MEDIA_TICKET_SECRET=
MEDIA_TICKET_TTL_SECONDS=180

# Optional analytics
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Transcode / playback
TRANSCODE_PROVIDER=manual
TRANSCODE_WEBHOOK_URL=
TRANSCODE_CALLBACK_SECRET=
TRANSCODE_SOURCE_TTL_SECONDS=3600

# Payment base URLs
PAYMENT_RETURN_URL_BASE=https://learn-flow-weld.vercel.app
PAYMENT_CALLBACK_SECRET=
PAYMENT_NOTIFICATION_WEBHOOK_URL=
PAYMENT_NOTIFICATION_WEBHOOK_SECRET=
PAYMENT_NOTIFY_OWNER=true
PAYMENT_DEFAULT_PROVIDER=alipay

# Alipay
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://learn-flow-weld.vercel.app/api/payments/alipay/notify
ALIPAY_RETURN_URL=https://learn-flow-weld.vercel.app/pricing

# WeChat Pay
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PLATFORM_PUBLIC_KEY=
WECHAT_PAY_NOTIFY_URL=https://learn-flow-weld.vercel.app/api/payments/wechat/notify

# Email / alerts
EMAIL_DELIVERY_MODE=log
EMAIL_WEBHOOK_URL=
EMAIL_WEBHOOK_SECRET=
RESEND_API_KEY=
RESEND_API_BASE_URL=https://api.resend.com
EMAIL_FROM_NAME=LearnFlow
EMAIL_FROM_ADDRESS=
ADMIN_ALERT_INBOX_ENABLED=true
ADMIN_ALERT_EMAIL_ENABLED=true
ADMIN_ALERT_WEBHOOK_URL=
ADMIN_ALERT_WEBHOOK_SECRET=

# Runtime policy
ADMIN_RISK_ESCALATE_AFTER_MINUTES=10
ADMIN_RISK_ESCALATE_REPEAT_MINUTES=30
